{
  "name": "@davyonix-company/http-client",
  "version": "0.1.0",
  "type": "module",
  "description": "Zero-dependency native fetch wrapper for internal microservices",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "clean": "rm -rf dist coverage"
  },
  "devDependencies": {
    "@davyonix-company/shared-configs": "workspace:*",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
